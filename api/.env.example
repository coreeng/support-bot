# Google OAuth2 Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Azure AD OAuth2 Configuration
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id

# Spring: loads application-local.yaml (jwt-groups for Dex/LDAP local stack, etc.). Login UI shows every IdP you configure below with full credentials (Google, Azure, Dex).
SPRING_PROFILES_ACTIVE=local

# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/postgres
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Slack Configuration
# Bot User OAuth Token (xoxb-...) from the app’s OAuth & Permissions page after install—not Incoming Webhook only.
SLACK_TOKEN=xoxb-your-bot-token
SLACK_SOCKET_TOKEN=xapp-your-socket-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_TICKET_CHANNEL_ID=C0000000000

# Required: JWT signing key (must be at least 256 bits)
JWT_SECRET=your-jwt-secret-minimum-256-bits

# Public UI base URL (scheme + host + port, no path). MUST match the origin of NEXTAUTH_URL on the Next.js app
# or proxied OAuth returns 400 on /auth/oauth-url and /auth/oauth/exchange. Defaults to http://localhost:3000 when unset.
# Outside local-like Spring profiles, the API logs a warning if UI_ORIGIN is unset.
#UI_ORIGIN=http://localhost:3000

# CORS Allowed Origins - REQUIRED for cross-origin requests
# Options:
#   "*" - Allow all origins (development only)
#   "example.com,myapp.io" - Allow specific domains and subdomains (HTTPS only)
#   Empty/unset - No CORS (same-origin only, most restrictive)
CORS_ALLOWED_ORIGINS=*

# Optional: Auth allow-list (uncomment to restrict SSO login)
# When both are empty/unset, all SSO-authenticated users are allowed.
#ALLOWED_EMAILS=gordon.freeman@blackmesa.net
#ALLOWED_DOMAINS=blackmesa.net

# Dex OIDC (optional)
#DEX_CLIENT_ID=support-bot-dex
#DEX_CLIENT_SECRET=replace-me
#DEX_ISSUER_URI=http://127.0.0.1:5556
#DEX_SCOPES=openid,email,profile,groups
# In-cluster: server-to-server URL for /token, /keys, /userinfo (client_secret sent here).
# Use the full svc FQDN to pass startup validation, e.g.:
#DEX_INTERNAL_BASE_URL=http://dex.<namespace>.svc.cluster.local:5556

# Dex LDAP → JWT groups → platform teams: enable in application.yaml under platform-integration.jwt-groups
# (Spring Boot binding for nested lists from env is awkward; prefer a profile yaml for local overrides.)

# Optional: Logging (uncomment to enable debug logging)
# AZURE_CLIENT_LOG_LEVEL=BODY
# LOGGING_LEVEL_COM_GOOGLE_API_CLIENT_HTTP=TRACE
# LOGGING_LEVEL_COM_SLACK_API=DEBUG
# LOGGING_LEVEL_IO_FABRIC8_KUBERNETES_CLIENT_HTTP=TRACE
