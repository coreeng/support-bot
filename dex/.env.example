DEX_ISSUER=http://127.0.0.1:5556
DEX_CLIENT_ID=support-bot-dex
DEX_CLIENT_SECRET=replace-me
DEX_REDIRECT_URI_1=http://localhost:8080/login/oauth2/code/dex
DEX_REDIRECT_URI_2=http://127.0.0.1:8080/login/oauth2/code/dex
DEX_LOCAL_USER_EMAIL=admin@example.com
DEX_LOCAL_USER_USERNAME=admin
DEX_LOCAL_USER_ID=08a8684b-db88-4b73-90a9-3cd1661f5466
# Example hash for password "admin"; replace for real usage.
DEX_LOCAL_USER_PASSWORD_HASH=$2a$10$6c9QhS23zYk8xH5fQ2fN4eWw6X8vY6A7gYVYsv5nYeD1yfknhkX9u

# Optional: Dex LDAP connector (Stage 3). After enabling, set API platform-integration.jwt-groups
# to map Dex "groups" claim values to platform team codes.
#DEX_LDAP_ENABLED=true
# Repo compose shares network "supportbot-ldap"; use the OpenLDAP service name:
#DEX_LDAP_HOST=openldap:389
# Alternative when LDAP is only published on the host (macOS/Windows):
#DEX_LDAP_HOST=host.docker.internal:389
#DEX_LDAP_BIND_DN=cn=admin,dc=supportbot,dc=local
#DEX_LDAP_BIND_PW=changeme
#DEX_LDAP_USER_SEARCH_BASE=ou=People,dc=supportbot,dc=local
#DEX_LDAP_GROUP_SEARCH_BASE=ou=Groups,dc=supportbot,dc=local
