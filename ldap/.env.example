# Copy to .env.local and set a strong password for local OpenLDAP admin.
LDAP_ADMIN_PASSWORD=changeme

# Optional: plaintext password for bootstrap users alice / bob (LDIF is generated before compose up).
# Default if unset: password123 (dev only). Override for non-default local or to match integration-ldap-test-user.
#LDAP_BOOTSTRAP_USER_PASSWORD=password123
