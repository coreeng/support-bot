# =============================================================================
# Required Environment Variables
# =============================================================================
# All variables below MUST be set. The app will not start without them.

# Internal backend API URL (server-side only, never exposed to browser)
# In Kubernetes: http://api-service.bot-api.svc.cluster.local:8080
BACKEND_URL=http://localhost:8080

# This app's public URL (for OAuth callbacks). The origin (scheme + host + port) must match UI_ORIGIN on the API
# (same value as security.oauth2.redirect-uri origin — see api/service/docs/configuration.md, UI origin contract).
# localhost vs 127.0.0.1 and ports are distinct; use one canonical URL everywhere.
# In production: https://ui.chatbot.com
NEXTAUTH_URL=http://localhost:3000

# Auth secret for JWT encryption
# Generate with: openssl rand -base64 32
AUTH_SECRET=
