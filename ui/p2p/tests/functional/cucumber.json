{
  "default": {
    "requireModule": ["ts-node/register"],
    "paths": ["tests/features/"],
    "require": ["tests/steps/*.ts"],
    "tags": "not @disabled",
    "timeout": 30000,
    "retry": 3,
    "formatOptions": {
      "snippetInterface": "async-await",
      "colorsEnabled": true
    },
    "format": [
      "summary",
      "progress",
      ["html", "cucumber-report.html"],
      ["json", "cucumber-report.json"]
    ]
  }
}
